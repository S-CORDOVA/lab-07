<h1>Appointments</h1>

<%= link_to "New Appointment", new_appointment_path, class: "btn btn-primary mb-3" %>

<table class="table table-striped table-bordered">
  <thead>
    <tr>
      <th>Date</th>
      <th>Pet name</th>
      <th>Vet name</th>
      <th>Reason</th>
      <th>Status</th>
      <th>Actions</th>
    </tr>
  </thead>

  <tbody>
    <% @appointments.each do |appointment| %>
      <tr>
        <td><%= link_to formatted_datetime(appointment.date), appointment_path(appointment) %></td>
        <td><%= link_to appointment.pet.name, pet_path(appointment.pet) %></td>
        <td><%= link_to "#{appointment.vet.first_name} #{appointment.vet.last_name}", vet_path(appointment.vet) %></td>
        <td><%= appointment.reason %></td>
        <td><%= appointment_status_text(appointment.status) %></td>
        <td>
          <%= link_to "Edit", edit_appointment_path(appointment), class: "btn btn-sm btn-secondary" %>
          <%= button_to "Delete", appointment_path(appointment), method: :delete, form: { data: { turbo_confirm: "Are you sure?" } }, class: "btn btn-sm btn-danger" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>