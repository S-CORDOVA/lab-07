<h1>Vets</h1>

<%= link_to "New Vet", new_vet_path, class: "btn btn-primary mb-3" %>

<table class="table table-striped table-bordered">
  <thead>
    <tr>
      <th>Full name</th>
      <th>Email</th>
      <th>Specialization</th>
      <th>Actions</th>
    </tr>
  </thead>

  <tbody>
    <% @vets.each do |vet| %>
      <tr>
        <td><%= link_to "#{vet.first_name} #{vet.last_name}", vet_path(vet) %></td>
        <td><%= vet.email %></td>
        <td><%= vet.specialization %></td>
        <td>
          <%= link_to "Edit", edit_vet_path(vet), class: "btn btn-sm btn-secondary" %>
          <%= button_to "Delete", vet_path(vet), method: :delete, form: { data: { turbo_confirm: "Are you sure?" } }, class: "btn btn-sm btn-danger" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>