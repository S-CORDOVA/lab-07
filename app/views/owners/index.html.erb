<h1>Owners</h1>

<%= link_to "New Owner", new_owner_path, class: "btn btn-primary mb-3" %>

<table class="table table-striped table-bordered">
  <thead>
    <tr>
      <th>Full name</th>
      <th>Email</th>
      <th>Phone</th>
      <th>Actions</th>
    </tr>
  </thead>

  <tbody>
    <% @owners.each do |owner| %>
      <tr>
        <td><%= link_to "#{owner.first_name} #{owner.last_name}", owner_path(owner) %></td>
        <td><%= owner.email %></td>
        <td><%= owner.phone %></td>
        <td>
          <%= link_to "Edit", edit_owner_path(owner), class: "btn btn-sm btn-secondary" %>
          <%= button_to "Delete", owner_path(owner), method: :delete, form: { data: { turbo_confirm: "Are you sure?" } }, class: "btn btn-sm btn-danger" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>