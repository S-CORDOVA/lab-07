<h1><%= @owner.first_name %> <%= @owner.last_name %></h1>

<p>Email: <%= @owner.email %></p>
<p>Phone: <%= @owner.phone %></p>
<p>Address: <%= @owner.address %></p>

<h2>Pets</h2>

<ul>
  <% @owner.pets.each do |pet| %>
    <li>
      <%= link_to pet.name, pet_path(pet) %>
    </li>
  <% end %>
</ul>

<%= link_to "Back", owners_path, class: "btn btn-secondary" %>

<%= link_to "Edit", edit_owner_path(@owner), class: "btn btn-secondary" %>
<%= button_to "Delete", @owner, method: :delete, form: { data: { turbo_confirm: "Are you sure?" } }, class: "btn btn-danger" %>